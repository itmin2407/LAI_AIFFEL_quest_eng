      "source": [
        "# vocab 프로젝션 레이어 + KDTrainer 정의\n",
        "import torch.nn.functional as F\n",
        "\n",
        "# ── vocab 크기 불일치 해결용 프로젝션 레이어 ──────────────────────────\n",
        "# teacher(63,998) → student(51,201) vocab 차원으로 맞춰줌\n",
        "vocab_projector = torch.nn.Linear(\n",
        "    len(teacher_tokenizer),  # 63,998\n",
        "    len(tokenizer),          # 51,201\n",
        "    bias=False\n",
        ").to(device)\n",
        "\n",
        "class KDTrainer(transformers.Trainer):\n",
        "    \"\"\"\n",
        "    Knowledge Distillation Trainer\n",
        "    teacher_model : kakaobrain (동결, 추론만)\n",
        "    model(student): skt/kogpt2 (학습 대상)\n",
        "    loss          : SFT loss + KD loss 가중합\n",
        "    \"\"\"\n",
        "\n",
        "    def compute_loss(self, model, inputs, return_outputs=False):\n",
        "        input_ids      = inputs[\"input_ids\"]\n",
        "        labels         = inputs[\"labels\"]\n",
        "        attention_mask = inputs[\"attention_mask\"]\n",
        "\n",
        "        # ── 1. Student forward ────────────────────────────────────────\n",
        "        student_outputs = model(\n",
        "            input_ids=input_ids,\n",
        "            attention_mask=attention_mask,\n",
        "            labels=labels\n",
        "        )\n",
        "        sft_loss       = student_outputs.loss           # Cross Entropy loss\n",
        "        student_logits = student_outputs.logits         # (batch, seq_len, 51201)\n",
        "\n",
        "        # ── 2. Teacher forward ────────────────────────────────────────\n",
        "        # student input_ids는 skt 토크나이저 기준\n",
        "        # → 텍스트로 복원 후 teacher 토크나이저로 재인코딩\n",
        "        with torch.no_grad():\n",
        "            texts = tokenizer.batch_decode(input_ids, skip_special_tokens=True)\n",
        "\n",
        "            teacher_inputs = teacher_tokenizer(\n",
        "                texts,\n",
        "                return_tensors=\"pt\",\n",
        "                padding=True,\n",
        "                truncation=True,\n",
        "                max_length=512\n",
        "            ).to(device)\n",
        "\n",
        "            teacher_outputs = teacher_model(**teacher_inputs)\n",
        "            teacher_logits  = teacher_outputs.logits    # (batch, seq_len', 63998)\n",
        "\n",
        "        # ── 3. vocab & sequence 길이 불일치 해결 ──────────────────────\n",
        "        # teacher vocab(63998) → student vocab(51201)으로 프로젝션\n",
        "        teacher_logits_projected = vocab_projector(teacher_logits)  # (batch, seq_len', 51201)\n",
        "\n",
        "        # sequence 길이를 짧은 쪽에 맞춰 정렬\n",
        "        min_len = min(student_logits.size(1), teacher_logits_projected.size(1))\n",
        "        student_logits_aligned = student_logits[:, :min_len, :]\n",
        "        teacher_logits_aligned = teacher_logits_projected[:, :min_len, :]\n",
        "\n",
        "        # ── 4. KD loss (KL Divergence) ────────────────────────────────\n",
        "        temperature = 2.0  # 높을수록 teacher 분포가 부드러워짐 (보통 2~4)\n",
        "        kd_loss = F.kl_div(\n",
        "            F.log_softmax(student_logits_aligned / temperature, dim=-1),\n",
        "            F.softmax(teacher_logits_aligned / temperature, dim=-1),\n",
        "            reduction=\"batchmean\"\n",
        "        ) * (temperature ** 2)\n",
        "\n",
        "        # ── 5. 최종 loss = SFT loss + KD loss 가중합 ──────────────────\n",
        "        alpha = 0.5  # 0.0: 순수 SFT, 1.0: 순수 KD\n",
        "        loss = (1 - alpha) * sft_loss + alpha * kd_loss\n",
        "\n",
        "        if self.state.global_step % 25 == 0:\n",
        "            print(f\"  step {self.state.global_step} | \"\n",
        "                  f\"total: {loss.item():.4f} | \"\n",
        "                  f\"sft: {sft_loss.item():.4f} | \"\n",
        "                  f\"kd: {kd_loss.item():.4f}\")\n",
        "\n",
        "        return (loss, student_outputs) if return_outputs else loss"
      ]
    },

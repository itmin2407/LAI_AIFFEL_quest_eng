      "cell_type": "markdown",
      "source": [
        "수정한 list_data_dict 반영해서 재학습 시작"
      ],
      "metadata": {
        "id": "TfTDua0MxqVU"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# 1. 수정된 list_data_dict로 train/eval 분리 및 변환\n",
        "random.seed(230301)\n",
        "random.shuffle(list_data_dict)\n",
        "\n",
        "train_size_raw = int(0.9 * len(list_data_dict))\n",
        "train_raw = list_data_dict[:train_size_raw]\n",
        "eval_raw  = list_data_dict[train_size_raw:]\n",
        "\n",
        "total_data_ranking2chosen = convert_ranking2chosen(train_raw)\n",
        "eval_data_ranking2chosen  = convert_ranking2chosen(eval_raw)\n",
        "\n",
        "train_data_RM = total_data_ranking2chosen\n",
        "eval_data_RM  = eval_data_ranking2chosen\n",
        "\n",
        "# train: 25164 / eval: 2799\n",
        "print(f\"train: {len(train_data_RM)} / eval: {len(eval_data_RM)}\")\n",
        "\n",
        "# 2. RewardDataset 재생성\n",
        "train_dataset_RM = RewardDataset(train_data_RM, rm_tokenizer, 512)\n",
        "eval_dataset_RM  = RewardDataset(eval_data_RM,  rm_tokenizer, 512)\n",
        "print(\"✅ RewardDataset 재생성 완료\")\n",
        "\n",
        "# 3. RM 재학습\n",
        "checkpoint_dir_RM = MODEL_DIR + '/rm_checkpoints'\n",
        "os.makedirs(checkpoint_dir_RM, exist_ok=True)\n",
        "\n",
        "epochs = 2  # 기존 3 → 5로 늘림\n",
        "\n",
        "# 옵티마이저를 루프 밖에서 한 번만 생성\n",
        "optimizer = torch.optim.Adam(rm_model.parameters(), lr=5e-5)\n",
        "\n",
        "for epoch in range(epochs):\n",
        "    print(f\"--- Epoch {epoch+1}/{epochs} Start ---\")\n",
        "\n",
        "    trainer_RM = CustomRewardModelTrainer(\n",
        "        model=rm_model,\n",
        "        strategy=NaiveStrategy(),\n",
        "        optim=optimizer,  # ← 동일한 옵티마이저 재사용\n",
        "        train_dataset=train_dataset_RM,\n",
        "        eval_dataset=eval_dataset_RM,\n",
        "        batch_size=4,\n",
        "        max_epochs=1\n",
        "    )\n",
        "\n",
        "    trainer_RM.fit(use_lora=0)\n",
        "\n",
        "    epoch_save_path = os.path.join(checkpoint_dir_RM, f\"checkpoint_epoch_{epoch+1}\")\n",
        "    rm_model.save_pretrained(epoch_save_path)\n",
        "    print(f\"✅ Epoch {epoch+1} checkpoint saved: {epoch_save_path}\")\n",
        "\n",
        "rm_model.save_pretrained(MODEL_DIR + '/checkpoint/output_2_RM')\n",
        "print(\"✅ RM 재학습 완료\")"
      ],

        "    print(f\"원본 ranking: {d['ranking']}\")\n",
        "\n",
        "    # 0 vs 1\n",
        "    r01 = compare_two(d['prompt'], d['completion_0'], d['completion_1'])\n",
        "    # 0 vs 2\n",

        "model = None\n",
        "gc.collect()\n",
        "torch.cuda.empty_cache()\n",
        "torch.cuda.synchronize()\n",
        "vram_status()\n",
        "\n",
        "# ── 2. Actor 로드 (SFT 결과물) ────────────────────────────────────────\n",
        "print(\"\\n2/5 Actor 로드 중...\")\n",
        "current_device = torch.cuda.current_device()\n",
        "\n",
        "with NaiveStrategy().model_init_context():\n",
        "    actor = GPTActor(\n",
        "        pretrained=MODEL_DIR + '/checkpoint/output_1_SFT',\n",
        "        lora_rank=0\n",
        "    ).to(current_device)\n",
        "print(\"   완료\")\n",
        "vram_status()\n",
        "\n",
        "# ── 3. Critic 설정 (rm_model 재사용) ──────────────────────────────────\n",
        "print(\"\\n3/5 Critic 설정 중...\")\n",
        "critic = rm_model\n",
        "print(\"   완료 (rm_model 재사용)\")\n",
        "vram_status()\n",
        "\n",
        "# ── 4. initial_model, reward_model 복사 ───────────────────────────────\n",
        "print(\"\\n4/5 initial_model, reward_model 복사 중...\")\n",
        "initial_model = deepcopy(actor)\n",
        "reward_model = RewardModel(\n",
        "    deepcopy(critic.model),\n",
        "    deepcopy(critic.value_head)\n",
        ").to(current_device)\n",
        "print(\"   완료\")\n",
        "vram_status()\n",
        "\n",
        "# ── 5. PPO 토크나이저 로드 ────────────────────────────────────────────\n",
        "print(\"\\n5/5 PPO 토크나이저 로드 중...\")\n",
        "ppo_tokenizer = AutoTokenizer.from_pretrained(\n",
        "    'kakaobrain/kogpt',\n",
        "    revision='KoGPT6B-ryan1.5b-float16',\n",
        "    padding_side=\"right\",\n",
        "    model_max_length=512,\n",
        ")\n",
        "ppo_tokenizer.add_special_tokens({\n",
        "    'bos_token': '[BOS]', 'eos_token': '[EOS]',\n",
        "    'unk_token': '[UNK]', 'pad_token': '[PAD]', 'mask_token': '[MASK]'\n",
        "})\n",
        "print(\"   완료\")\n",
        "\n",
        "print(\"\\n✅ PPO 모델 초기화 완료\")"
      ],
      "metadata": {
        "id": "5rbR2nWBea7c"
      },
      "execution_count": null,
      "outputs": []

      },
      "outputs": [],
      "source": [
        "# top_k 샘플링: 전체 vocab중 확률 상위 k개 토큰만 후보로 남기고 나머지는 버림\n",
        "# 아래 코드는 그 k개 안에서 temperature로 조정된 확률로 샘플링함.\n",
        "output_beam = model.generate(input_ids, max_length=max_length, num_beams=7, no_repeat_ngram_size=2,\n",
        "                             do_sample=True, temperature=2.0, top_k=50)\n",
        "print2(tokenizer.decode(output_beam[0]))"
      ]

      "source": [
        "def evaluate_rm(rm_model, eval_dataset_RM, batch_size=8):\n",
        "    from torch.utils.data import DataLoader\n",
        "\n",
        "    def collate_fn_reward(batch):\n",
        "        chosen_ids   = torch.cat([b[0] for b in batch], dim=0)\n",
        "        chosen_mask  = torch.cat([b[1] for b in batch], dim=0)\n",
        "        rejected_ids  = torch.cat([b[2] for b in batch], dim=0)\n",
        "        rejected_mask = torch.cat([b[3] for b in batch], dim=0)\n",
        "        return {\n",
        "            'input_ids_chosen':        chosen_ids,\n",
        "            'attention_mask_chosen':   chosen_mask,\n",
        "            'input_ids_rejected':      rejected_ids,\n",
        "            'attention_mask_rejected': rejected_mask,\n",
        "        }\n",
        "\n",
        "    rm_model.eval()\n",
        "    correct = 0\n",
        "    total = 0\n",
        "\n",
        "    eval_loader = DataLoader(\n",
        "        eval_dataset_RM, batch_size=batch_size, shuffle=False, collate_fn=collate_fn_reward\n",
        "    )\n",
        "\n",
        "    with torch.no_grad():\n",
        "        for batch in eval_loader:\n",
        "            chosen_ids   = batch['input_ids_chosen'].cuda()\n",
        "            rejected_ids = batch['input_ids_rejected'].cuda()\n",
        "\n",
        "            chosen_scores  = rm_model(chosen_ids)\n",
        "            rejected_scores = rm_model(rejected_ids)\n",
        "\n",
        "            correct += (chosen_scores > rejected_scores).sum().item()\n",
        "            total   += chosen_ids.size(0)\n",
        "\n",
        "            if total % 100 == 0:\n",
        "                print(f\"진행중: {total} | accuracy: {correct/total:.1%}\")\n",
        "\n",
        "    accuracy = correct / total\n",
        "    print(f\"\\n✅ 전체 eval accuracy: {accuracy:.1%} ({correct}/{total})\")\n",
        "    return accuracy\n",
        "\n",
        "\n",
        "# 사용\n",
        "accuracy = evaluate_rm(rm_model, eval_dataset_RM)"
      ],

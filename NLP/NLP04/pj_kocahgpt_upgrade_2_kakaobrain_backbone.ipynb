      "source": [
        "# perplexity 점수를 구해서 worst와 best 답변을 비교\n",
        "# best가 더 나을때는 그대로, worst가 더 나을 때는 best와 worst를 스왑\n",
        "# 비교 결과는 ranking_quality_check.txt 파일로 저장\n",
        "import os\n",
        "\n",
        "def get_perplexity(text):\n",
        "    input_ids = tokenizer.encode(text, return_tensors='pt').to(device)\n",
        "    with torch.no_grad():\n",
        "        outputs = model(input_ids, labels=input_ids)\n",
        "        loss = outputs.loss\n",
        "    return torch.exp(loss).item()\n",
        "\n",
        "def compare_two_ppl(prompt, text_a, text_b):\n",
        "    ppl_a = get_perplexity(f\"{prompt} {text_a}\")\n",
        "    ppl_b = get_perplexity(f\"{prompt} {text_b}\")\n",
        "    return 1 if ppl_a < ppl_b else 2  # perplexity 낮을수록 좋음\n",
        "\n",
        "output_path = os.path.join(mypath, 'ranking_quality_check.txt')\n",
        "results_perplexity = []  # 1 또는 0을 담는 리스트\n",
        "\n",
        "# 1단계: perplexity 비교 결과 수집\n",
        "with open(output_path, 'w', encoding='utf-8') as f:\n",
        "    for i, d in enumerate(list_data_dict):\n",
        "        try:\n",
        "            best_idx  = d['ranking'].index(0)\n",
        "            worst_idx = d['ranking'].index(2)\n",
        "\n",
        "            result = compare_two_ppl(\n",
        "                d['prompt'],\n",
        "                d[f'completion_{best_idx}'],\n",
        "                d[f'completion_{worst_idx}']\n",
        "            )\n",
        "\n",
        "            is_correct = 1 if result == 1 else 0\n",
        "            results_perplexity.append(is_correct)\n",
        "\n",
        "            line = (\n",
        "                f\"[{i}번] {'✅' if is_correct else '❌'} | \"\n",
        "                f\"prompt: {d['prompt'][:50]} | \"\n",
        "                f\"ranking: {d['ranking']}\\n\"\n",
        "                f\"  ranking=0: {d[f'completion_{best_idx}'][:80]}\\n\"\n",
        "                f\"  ranking=2: {d[f'completion_{worst_idx}'][:80]}\\n\"\n",
        "            )\n",
        "            f.write(line)\n",
        "            f.flush()\n",
        "\n",
        "            if i % 100 == 0:\n",
        "                print(f\"진행중: {i}/{len(list_data_dict)}\")\n",
        "\n",
        "        except Exception as e:\n",
        "            results_perplexity.append(None)\n",
        "            f.write(f\"[{i}번] 오류: {e}\\n\")\n",
        "            f.flush()\n",
        "\n",
        "print(f\"✅ perplexity 비교 완료\")\n",
        "print(f\"정확도: {sum(r for r in results_perplexity if r is not None) / len([r for r in results_perplexity if r is not None]):.1%}\")\n",
        "\n",
        "# 2단계: 결과가 0인 데이터의 ranking 뒤집기\n",
        "corrected_count = 0\n",
        "# `d`는 `list_data_dict[i]`를 가리키는 참조. list_data_dict 원본을 직접 수정하고 있음.\n",
        "for i, (d, result) in enumerate(zip(list_data_dict, results_perplexity)):\n",
        "    if result == 0:\n",
        "        best_idx  = d['ranking'].index(0)\n",
        "        worst_idx = d['ranking'].index(2)\n",
        "\n",
        "        # ranking 뒤집기: best↔worst 교환\n",
        "        d['ranking'][best_idx]  = 2\n",
        "        d['ranking'][worst_idx] = 0\n",
        "        corrected_count += 1\n",
        "\n",
        "print(f\"✅ ranking 수정 완료: {corrected_count}개 뒤집음\")"

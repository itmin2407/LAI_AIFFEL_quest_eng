        "print(f\"BOS 토큰 ID: {tokenizer.bos_token_id}\")\n",
        "print(f\"PAD 토큰 ID: {tokenizer.pad_token_id}\")\n",
        "print(\"-\" * 50)\n",
        "\n",
        "# 3. 한국어 인코딩/디코딩 테스트\n",

    {
      "cell_type": "code",
      "source": [
        "# 이전에 학습해놓은 모델이 있다면 불러오기\n",
        "from peft import PeftModel, prepare_model_for_kbit_training\n",
        "from safetensors import safe_open\n",
        "\n",
        "# 베이스 모델부터 다시 부르기\n",
        "model = None\n",
        "\n",
        "clean_memory()\n",
        "print()\n",
        "\n",
        "bnb_config = BitsAndBytesConfig(\n",
        "    load_in_8bit=True,  # 가중치를 INT8로 압축해서 로드하고, GPU에서 INT8로 연산하게 한다.\n",
        "    llm_int8_enable_fp32_cpu_offload=True  # CPU로 보내진 데이터는 float32로 연산하게 한다.\n",
        ")\n",
        "model = AutoModelForCausalLM.from_pretrained(\n",
        "    'kakaobrain/kogpt',\n",
        "    revision='KoGPT6B-ryan1.5b-float16',  # or float32 version: revision=KoGPT6B-ryan1.5b\n",
        "    pad_token_id=tokenizer.pad_token_id,\n",
        "    low_cpu_mem_usage=True,\n",
        "    quantization_config=bnb_config,      # 양자화 옵션 묶음 -> (VRAM 약 6~7GB 예상)\n",
        "    device_map=\"auto\",       # 자동으로 GPU/CPU 분산 로드\n",
        ")\n",
        "print()\n",
        "clean_memory()\n",
        "\n",
        "# 2. kbit training 준비 (학습 당시와 동일하게)\n",
        "model = prepare_model_for_kbit_training(model)\n",
        "\n",
        "# 3. LoRA adapter 로드\n",
        "model = PeftModel.from_pretrained(\n",
        "    model,\n",
        "    MODEL_DIR + '/checkpoint/output_1_SFT',\n",
        "    is_trainable=True\n",
        ")\n",
        "\n",
        "print(\"✅ SFT 모델 로드 완료\")\n",
        "\n",
        "# 불러온 모델 확인\n",
        "# 1. 타입 확인\n",
        "print(type(model))  # PeftModelForCausalLM 이어야 함\n",
        "# <class 'peft.peft_model.PeftModelForCausalLM'>\n",
        "\n",
        "# 2. 파라미터 확인 & adapter 가중치가 실제로 로드됐는지 확인\n",
        "model.print_trainable_parameters()\n",
        "# trainable params: 0 || all params: 6,173,842,432 || trainable%: 0.0000\n",
        "adapter_path = MODEL_DIR + '/checkpoint/output_1_SFT/adapter_model.safetensors'\n",
        "# 저장된 가중치 값\n",
        "with safe_open(adapter_path, framework=\"pt\") as f:\n",
        "    saved_weight = f.get_tensor('base_model.model.transformer.h.0.attn.k_proj.lora_A.weight')\n",
        "# 현재 모델의 가중치 값\n",
        "current_weight = dict(model.named_parameters())['base_model.model.transformer.h.0.attn.k_proj.lora_A.default.weight']\n",
        "print()\n",
        "print(\"저장된 가중치:\", saved_weight[0][:5])\n",
        "print(\"현재 모델 가중치:\", current_weight[0][:5])\n",
        "print(\"일치 여부:\", torch.allclose(saved_weight.cpu().float(), current_weight.cpu().float()))\n",
        "print()\n",
        "\n",
        "# 3. 실제 추론으로 확인 (가장 확실한 방법)\n",
        "model.eval()\n",
        "prompt = \"### Instruction(명령어):\\n바람이 분다\\n\\n### Response(응답):\"\n",
        "input_ids = tokenizer.encode(prompt, return_tensors='pt').to(device)\n",
        "\n",
        "with torch.no_grad():\n",
        "    output = model.generate(\n",
        "        input_ids,\n",
        "        max_new_tokens=50,\n",
        "        do_sample=True,\n",
        "        temperature=0.8,\n",
        "        eos_token_id=tokenizer.eos_token_id,\n",
        "        pad_token_id=tokenizer.pad_token_id,\n",
        "    )\n",
        "\n",
        "print2(tokenizer.decode(output[0], skip_special_tokens=False))"

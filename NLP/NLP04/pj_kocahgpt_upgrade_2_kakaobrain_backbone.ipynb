    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "B-ozSgDgs5Hr"
      },
      "outputs": [],
      "source": [
        "# 긴 텍스트 출력시 화면 밖으로 안넘치게 보여주는 함수 정의\n",
        "def print2(r):\n",
        "    # 문자열이 아닌 타입은 str로 변환\n",
        "    if not isinstance(r, str):\n",
        "        r = str(r)\n",
        "    step = 80\n",
        "    for i in range(0, len(r), step):\n",
        "        print(r[i:i + step])"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"

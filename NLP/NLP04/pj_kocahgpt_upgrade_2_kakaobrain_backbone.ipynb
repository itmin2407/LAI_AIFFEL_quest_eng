      },
      "outputs": [],
      "source": [
        "# KDTrainer로 학습 실행\n",
        "training_args = transformers.TrainingArguments(\n",
        "    output_dir=MODEL_DIR + \"/checkpoint\",\n",
        "    overwrite_output_dir=True,\n",
        "    num_train_epochs=3,\n",
        "    per_device_train_batch_size=4,\n",
        "    gradient_accumulation_steps=2,\n",
        "    gradient_checkpointing=True,\n",
        "    fp16=True,\n",
        "    prediction_loss_only=True,\n",
        "    save_strategy=\"epoch\",\n",
        "    evaluation_strategy=\"epoch\",\n",
        "    eval_steps=100,\n",
        "    save_steps=100,\n",
        "    save_total_limit=3,\n",
        "    load_best_model_at_end=True,\n",
        "    logging_steps=25,\n",
        "    metric_for_best_model=\"loss\"\n",
        ")\n",
        "\n",
        "# Trainer → KDTrainer로 교체 (나머지 인자 동일)\n",
        "trainer = KDTrainer(\n",
        "    model=model,\n",
        "    args=training_args,\n",
        "    data_collator=data_collator,\n",
        "    train_dataset=train_dataset,\n",
        "    eval_dataset=eval_dataset\n",
        ")\n",
        "\n",
        "trainer.train()\n",
        "model.save_pretrained(MODEL_DIR + '/checkpoint/output_1_SFT')\n",
        "\n",
        "\"\"\"\n",
        "## 최종 구조 요약\n",
        "\n",
        "teacher_model  = kakaobrain (int8, 동결) ← 셀 18의 model 보존\n",
        "teacher_tokenizer = kakaobrain tokenizer ← 셀 15의 tokenizer 보존\n",
        "\n",
        "model     = skt/kogpt2 (fp32, 학습 대상)\n",
        "tokenizer = skt/kogpt2 tokenizer\n",
        "\n",
        "학습 흐름:\n",
        "텍스트 → student tokenizer 인코딩 → student forward → sft_loss\n",
        "텍스트 → teacher tokenizer 재인코딩 → teacher forward → vocab 프로젝션 → kd_loss\n",
        "최종 loss = 0.5 * sft_loss + 0.5 * kd_loss → student만 업데이트\n",
        "\"\"\""
      ]
    }
  ],

        "# 2. 스페셜 토큰 추가 (필요한 경우)\n",
        "special_tokens_dict = {\n",
        "    'bos_token': '[BOS]',\n",
        "    'eos_token': '[EOS]',\n",
        "    'unk_token': '[UNK]',\n",
        "    'pad_token': '[PAD]',\n",
        "    'mask_token': '[MASK]'\n",
        "}\n",
        "\n",
        "tokenizer.add_special_tokens(special_tokens_dict)\n",
        "tokenizer.model_max_length = 512\n",
        "\n",
        "print(f\"토크나이저 로드 후 VRAM: {torch.cuda.memory_allocated() / 1024**3:.2f} GB\")"

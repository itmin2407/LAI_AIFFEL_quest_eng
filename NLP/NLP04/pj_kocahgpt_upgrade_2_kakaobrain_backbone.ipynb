        "def is_english_response(text):\n",
        "    english_chars = sum(1 for c in text if 'a' <= c.lower() <= 'z')\n",
        "    return english_chars / max(len(text), 1) > 0.5  # 50% 이상 영어면 영어 답변\n",
        "\n",
        "def filter_broken_text(data_list):\n",
        "    valid_data = []\n",
        "    removed_count = 0\n",
        "\n",
        "    for tmp in data_list:\n",
        "        ranking = tmp['ranking']\n",
        "        best_idx  = ranking.index(0)\n",
        "        worst_idx = ranking.index(2)\n",
        "\n",
        "        best_completion  = tmp[f'completion_{best_idx}']\n",
        "        worst_completion = tmp[f'completion_{worst_idx}']\n",
        "\n",
        "        best_korean  = sum(1 for c in best_completion  if '가' <= c <= '힣')\n",
        "        worst_korean = sum(1 for c in worst_completion if '가' <= c <= '힣')\n",
        "\n",
        "        best_ok  = len(best_completion)  >= 4 and best_korean  >= 4\n",
        "        worst_ok = len(worst_completion) >= 4 and worst_korean >= 4\n",
        "\n",
        "        # 질문이 한국어인데 best 답변이 영어인 경우 제거\n",
        "        prompt_korean = sum(1 for c in tmp['prompt'] if '가' <= c <= '힣')\n",
        "        if prompt_korean >= 3 and is_english_response(best_completion):\n",
        "            best_ok = False\n",
        "\n",
        "        if best_ok and worst_ok:\n",
        "            valid_data.append(tmp)\n",
        "        else:\n",
        "            removed_count += 1\n",
        "\n",
        "    print(f\"필터링 전: {len(data_list)}\")\n",
        "    print(f\"필터링 후: {len(valid_data)}\")\n",
        "    print(f\"제거된 수: {removed_count} ({removed_count/len(data_list)*100:.1f}%)\")\n",
        "\n",
        "    return valid_data\n",
        "\n",
        "list_data_dict_filtered = filter_broken_text(list_data_dict)\n",
        "rm_score_judge(list_data_dict_filtered)"

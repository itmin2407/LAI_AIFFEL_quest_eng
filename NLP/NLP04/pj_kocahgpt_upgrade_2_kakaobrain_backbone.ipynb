      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "model: <class 'NoneType'>\n",
            "----- GPU 메모리 청소전 -----\n",
            "VRAM 총량: 22.0 GB\n",
            "VRAM 사용 중: 0.00 GB\n",
            "VRAM 여유: 22.03 GB\n",
            "\n",
            "---------- 청소후 ----------\n",
            "VRAM 총량: 22.0 GB\n",

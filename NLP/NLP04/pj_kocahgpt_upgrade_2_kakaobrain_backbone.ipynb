      "source": [
        "# ── RM 학습 ────────────────────────────────────────────────────────────\n",
        "import torch\n",
        "\n",
        "checkpoint_dir_RM = MODEL_DIR + '/checkpoint/output_2_RM'\n",
        "os.makedirs(checkpoint_dir_RM, exist_ok=True)\n",
        "\n",
        "epochs = 2\n",
        "\n",
        "# 옵티마이저를 루프 밖에서 한 번만 생성\n",
        "optimizer = torch.optim.Adam(rm_model.parameters(), lr=5e-5)\n",
        "\n",
        "for epoch in range(epochs):\n",
        "    print(f\"--- Epoch {epoch+1}/{epochs} Start ---\")\n",
        "\n",
        "    trainer_RM = CustomRewardModelTrainer(\n",
        "        model=rm_model,\n",
        "        strategy=NaiveStrategy(),\n",
        "        optim=optimizer,  # ← 동일한 옵티마이저 재사용\n",
        "        train_dataset=train_dataset_RM,\n",
        "        eval_dataset=eval_dataset_RM,\n",
        "        batch_size=4,\n",
        "        max_epochs=1\n",
        "    )\n",
        "\n",
        "    trainer_RM.fit(use_lora=0)\n",
        "\n",
        "    epoch_save_path = os.path.join(checkpoint_dir_RM, f\"rm_epoch_{epoch+1}\")\n",
        "\n",
        "    # 체크포인트 저장\n",
        "    rm_model.save_pretrained(epoch_save_path)           # GPT2Model\n",
        "    torch.save(rm_model.value_head.state_dict(),\n",
        "               epoch_save_path + '/value_head.pt')      # value_head\n",
        "    torch.save(optimizer.state_dict(),\n",
        "               epoch_save_path + '/optimizer.pt')       # 옵티마이저\n",

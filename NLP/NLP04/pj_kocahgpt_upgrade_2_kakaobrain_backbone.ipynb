      "cell_type": "code",
      "source": [
        "def check_ranking_quality(data_list, n_examples=3):\n",
        "    invalid_count = 0\n",
        "    swapped_count = 0\n",
        "    invalid_examples = []\n",
        "\n",
        "    for i, tmp in enumerate(data_list):\n",
        "        ranking = tmp['ranking']\n",
        "\n",
        "        # 1. ranking 값이 0,1,2로 구성되어 있는지 확인\n",
        "        if sorted(ranking) != [0, 1, 2]:\n",
        "            invalid_count += 1\n",
        "            invalid_examples.append({'idx': i, 'reason': 'ranking값 이상', 'data': tmp})\n",
        "            continue\n",
        "\n",
        "        # 2. ranking=0인 completion이 실제로 가장 좋은 답변인지 육안 확인용 샘플 추출\n",
        "        best_idx = ranking.index(0)\n",
        "        best_completion = tmp[f'completion_{best_idx}']\n",
        "        korean_chars = sum(1 for c in best_completion if '가' <= c <= '힣')\n",
        "\n",
        "        # ranking=0인데 텍스트가 깨진 경우\n",
        "        if len(best_completion) < 10 or korean_chars < 5:\n",
        "            worst_idx = ranking.index(2)\n",
        "            worst_completion = tmp[f'completion_{worst_idx}']\n",
        "            worst_korean_chars = sum(1 for c in worst_completion if '가' <= c <= '힣')\n",
        "\n",
        "            mid_idx = ranking.index(1)\n",
        "            mid_completion = tmp[f'completion_{mid_idx}']\n",
        "            mid_korean_chars = sum(1 for c in mid_completion if '가' <= c <= '힣')\n",
        "\n",
        "            worst_ok = len(worst_completion) >= 4 and worst_korean_chars >= 4\n",
        "            mid_ok   = len(mid_completion)   >= 4 and mid_korean_chars   >= 4\n",
        "\n",
        "            if not worst_ok and not mid_ok:\n",
        "                # 셋 다 깨진 경우 제거\n",
        "                invalid_count += 1\n",
        "                invalid_examples.append({'idx': i, 'reason': '셋 다 텍스트 깨짐', 'data': tmp})\n",
        "            elif not worst_ok and mid_ok:\n",
        "                # ranking=0과 2가 깨진 경우 → best↔mid 스왑\n",
        "                ranking[best_idx], ranking[mid_idx] = ranking[mid_idx], ranking[best_idx]\n",
        "                swapped_count += 1\n",
        "            else:\n",
        "                # ranking=0만 깨진 경우 → best↔worst 스왑\n",
        "                ranking[best_idx], ranking[worst_idx] = ranking[worst_idx], ranking[best_idx]\n",
        "                swapped_count += 1\n",
        "\n",
        "        # 스왑 후 혹은 best가 처음부터 정상인 경우 → 한글 질문에 영어 답변 체크\n",
        "        best_idx = ranking.index(0)  # ← 스왑 후 갱신\n",
        "        best_completion = tmp[f'completion_{best_idx}']\n",
        "        prompt_korean = sum(1 for c in tmp['prompt'] if '가' <= c <= '힣')\n",
        "        english_chars = sum(1 for c in best_completion if 'a' <= c.lower() <= 'z')\n",
        "        is_english = english_chars / max(len(best_completion), 1) > 0.5\n",
        "        if prompt_korean >= 3 and is_english:\n",
        "            worst_idx = ranking.index(2)\n",
        "            ranking[best_idx], ranking[worst_idx] = ranking[worst_idx], ranking[best_idx]\n",
        "            swapped_count += 1\n",
        "\n",
        "    invalid_indices = {ex['idx'] for ex in invalid_examples}\n",
        "    filtered_data = [tmp for i, tmp in enumerate(data_list) if i not in invalid_indices]\n",
        "\n",
        "    print(f\"총 데이터: {len(data_list)}\")\n",
        "    print(f\"제거된 수: {invalid_count} ({invalid_count/len(data_list)*100:.1f}%)\")\n",
        "    print(f\"스왑된 수: {swapped_count} ({swapped_count/len(data_list)*100:.1f}%)\")\n",
        "    print(f\"최종 데이터: {len(filtered_data)}\")\n",
        "    print()\n",
        "    print(f\"--- 문제 데이터 예시 (최대 {n_examples}개) ---\")\n",
        "    for ex in invalid_examples[:n_examples]:\n",
        "        r = ex['data']['ranking']\n",
        "        best_i  = r.index(0)\n",
        "        worst_i = r.index(2)\n",
        "        mid_i   = r.index(1)\n",
        "        print(f\"index: {ex['idx']}\")\n",
        "        print(f\"prompt: {ex['data']['prompt']}\")\n",
        "        print(f\"reason: {ex['reason']}\")\n",
        "        print(f\"ranking: {r}\")\n",
        "        print(f\"best  (ranking=0): {ex['data'][f'completion_{best_i}'][:50]}\")\n",
        "        print(f\"mid   (ranking=1): {ex['data'][f'completion_{mid_i}'][:50]}\")\n",
        "        print(f\"worst (ranking=2): {ex['data'][f'completion_{worst_i}'][:50]}\")\n",
        "        print()\n",
        "\n",
        "    return invalid_examples, filtered_data"
      ],
